{
  "name": "ssh-sync",
  "displayName": "SSH Sync",
  "description": "Synchronize a local folder with a remote SSH folder using ssh/scp.",
  "version": "0.0.1",
  "publisher": "ghost233lism",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghost233lism/ssh-sync.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sshSync.bindFolder",
    "onCommand:sshSync.syncNow",
    "onCommand:sshSync.openRemoteFolder",
    "onCommand:sshSync.refreshRemoteExplorer",
    "onCommand:sshSync.newRemoteFile",
    "onCommand:sshSync.newRemoteFolder",
    "onCommand:sshSync.openRemoteTerminal",
    "onCommand:sshSync.unbindFolder",
    "onTerminalProfile:sshSync.remoteTerminal",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sshSync.bindFolder",
        "title": "SSH Sync: Bind Folder"
      },
      {
        "command": "sshSync.syncNow",
        "title": "SSH Sync: Sync Now"
      },
      {
        "command": "sshSync.openRemoteFolder",
        "title": "SSH Sync: Open Remote Folder",
        "icon": "$(remote-explorer)"
      },
      {
        "command": "sshSync.refreshRemoteExplorer",
        "title": "SSH Sync: Refresh Remote Folder",
        "icon": "$(refresh)"
      },
      {
        "command": "sshSync.newRemoteFile",
        "title": "SSH Sync: New Remote File",
        "icon": "$(new-file)"
      },
      {
        "command": "sshSync.newRemoteFolder",
        "title": "SSH Sync: New Remote Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "sshSync.openRemoteTerminal",
        "title": "SSH Sync: Open Remote Terminal"
      },
      {
        "command": "sshSync.unbindFolder",
        "title": "SSH Sync: Unbind Folder"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "sshSync.remoteTerminal",
          "title": "SSH Sync Remote Terminal",
          "icon": "remote"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "sshSync.remoteExplorer",
          "name": "SSH Sync Remote"
        }
      ]
    },
    "menus": {
      "file/newFile": [
        {
          "command": "sshSync.openRemoteFolder",
          "group": "navigation@30"
        }
      ],
      "view/title": [
        {
          "command": "sshSync.newRemoteFile",
          "when": "view == sshSync.remoteExplorer",
          "group": "navigation@1"
        },
        {
          "command": "sshSync.newRemoteFolder",
          "when": "view == sshSync.remoteExplorer",
          "group": "navigation@2"
        },
        {
          "command": "sshSync.refreshRemoteExplorer",
          "when": "view == sshSync.remoteExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "sshSync.newRemoteFile",
          "when": "view == sshSync.remoteExplorer && viewItem == directory",
          "group": "inline@1"
        },
        {
          "command": "sshSync.newRemoteFolder",
          "when": "view == sshSync.remoteExplorer && viewItem == directory",
          "group": "inline@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sshSync.remoteExplorer",
        "contents": "[Open Remote Folder](command:sshSync.openRemoteFolder)"
      }
    ],
    "configuration": {
      "title": "SSH Sync",
      "properties": {
        "sshSync.defaultPollInterval": {
          "type": "number",
          "default": 500,
          "minimum": 500,
          "description": "Default remote polling interval in milliseconds when sync-setting.json uses realtime or is missing."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
